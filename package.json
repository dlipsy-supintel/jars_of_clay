  "type": "module",
  "bugs": {
    "url": "https://github.com/dlipsy-supintel/jars_of_clay/issues"
  },
  "homepage": "https://github.com/dlipsy-supintel/jars_of_clay#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }

{
  "name": "jars_of_clay",
  "version": "1.0.0",
  "description": "A startup-friendly blueprint for building a self-hosted GTM intelligence platform that replaces [Clay](https://clay.com) with **RuVector** + **Claude API** + direct data provider integrations.",
  "main": "src/api/server.ts",
  "scripts": {
    "dev": "tsx src/api/server.ts",
    "enrich": "tsx src/examples/enrichment-pipeline.ts",
    "build": "tsc",
    "start": "node dist/api/server.js",
    "validate": "bash scripts/validate-deps.sh",
    "assemble": "bash scripts/assemble-guide.sh",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dlipsy-supintel/jars_of_clay.git"
  },
  "keywords": [],
